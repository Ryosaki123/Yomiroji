diff --git a/irodori_tts/offline_paths.py b/irodori_tts/offline_paths.py
new file mode 100644
index 0000000..f4223cc
--- /dev/null
+++ b/irodori_tts/offline_paths.py
@@ -0,0 +1,83 @@
+from __future__ import annotations
+
+import os
+from pathlib import Path
+
+
+BASE_MODEL_REPO = "Aratako/Irodori-TTS-500M-v3"
+BASE_MODEL_V2_REPO = "Aratako/Irodori-TTS-500M-v2"
+VOICEDESIGN_MODEL_REPO = "Aratako/Irodori-TTS-500M-v2-VoiceDesign"
+CODEC_REPO = "Aratako/Semantic-DACVAE-Japanese-32dim"
+
+_CHECKPOINT_FILES = {
+    BASE_MODEL_REPO.lower(): ("base", "model.safetensors"),
+    BASE_MODEL_V2_REPO.lower(): ("base_v2", "model.safetensors"),
+    VOICEDESIGN_MODEL_REPO.lower(): ("voicedesign", "model.safetensors"),
+}
+
+_MODEL_DIRS = {
+    CODEC_REPO.lower(): ("codec",),
+}
+
+
+def bundle_root() -> Path:
+    return Path(__file__).resolve().parents[2]
+
+
+def models_dir() -> Path:
+    raw = os.environ.get("IRODORI_TTS_MODELS_DIR", "").strip()
+    if raw:
+        return Path(raw).expanduser().resolve()
+    return bundle_root() / "models"
+
+
+def tokenizers_dir() -> Path:
+    return models_dir() / "tokenizers"
+
+
+def repo_dir_name(repo_id: str) -> str:
+    return str(repo_id).strip().replace("/", "__")
+
+
+def resolve_checkpoint_reference(reference: str) -> str:
+    value = str(reference).strip()
+    local = Path(value).expanduser()
+    if local.is_file():
+        return str(local)
+
+    parts = _CHECKPOINT_FILES.get(value.lower())
+    if parts is not None:
+        candidate = models_dir().joinpath(*parts)
+        if candidate.is_file():
+            return str(candidate)
+    return value
+
+
+def resolve_model_reference(reference: str) -> str:
+    value = str(reference).strip()
+    local = Path(value).expanduser()
+    if local.exists():
+        if local.is_dir() and (local / "weights.pth").is_file():
+            return str(local / "weights.pth")
+        return str(local)
+
+    parts = _MODEL_DIRS.get(value.lower())
+    if parts is not None:
+        candidate = models_dir().joinpath(*parts)
+        if candidate.is_dir() and (candidate / "weights.pth").is_file():
+            return str(candidate / "weights.pth")
+        if candidate.exists():
+            return str(candidate)
+    return value
+
+
+def resolve_tokenizer_reference(repo_id: str) -> tuple[str, bool]:
+    value = str(repo_id).strip()
+    local = Path(value).expanduser()
+    if local.exists():
+        return str(local), True
+
+    candidate = tokenizers_dir() / repo_dir_name(value)
+    if candidate.exists():
+        return str(candidate), True
+    return value, False
