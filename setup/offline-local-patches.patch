+
+
+def _apply_editor_range(
+    source_audio: object,
+    start_seconds: float,
+    end_seconds: float,
+    history: list[str] | None,
+    operation: str,
+) -> tuple[str, str, list[str], list[str], object, object, object]:
+    path, status, new_history, redo_stack = apply_range_edit(
+        source_audio,
+        start_seconds,
+        end_seconds,
+        operation,
+        history,
+    )
+    duration = audio_duration_seconds(path)
+    start_update, end_update = _selection_updates(duration, full_range=True)
+    return path, status, new_history, redo_stack, start_update, end_update, _insert_point_update(duration)
+
+
+def _trim_editor_audio(
+    source_audio: object,
+    start_seconds: float,
+    end_seconds: float,
+    history: list[str] | None,
+) -> tuple[str, str, list[str], list[str], object, object, object]:
+    return _apply_editor_range(source_audio, start_seconds, end_seconds, history, "trim")
+
+
+def _cut_editor_audio(
+    source_audio: object,
+    start_seconds: float,
+    end_seconds: float,
+    history: list[str] | None,
