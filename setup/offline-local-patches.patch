diff --git a/irodori_tts/audio_editor.py b/irodori_tts/audio_editor.py
new file mode 100644
index 0000000..86e60a0
--- /dev/null
+++ b/irodori_tts/audio_editor.py
@@ -0,0 +1,199 @@
+from __future__ import annotations
+
+from datetime import datetime
+from os import PathLike
+from pathlib import Path
+
+import numpy as np
+
+
+def _coerce_audio_path(value: object) -> Path:
+    if value is None:
+        raise ValueError("Audio file is required.")
+    if isinstance(value, str | PathLike):
+        path = Path(value)
+    elif isinstance(value, dict):
+        candidate = value.get("path") or value.get("name")
+        path = Path(str(candidate).strip()) if candidate else Path()
+    else:
+        candidate = getattr(value, "name", None)
+        path = Path(str(candidate).strip()) if candidate else Path(str(value).strip())
+    if not path.is_file():
+        raise FileNotFoundError(f"Audio file not found: {path}")
+    return path
+
+
+def _read_audio(path: Path) -> tuple[np.ndarray, int]:
+    import soundfile as sf
+
+    audio, sample_rate = sf.read(str(path), dtype="float32", always_2d=True)
+    return audio, int(sample_rate)
+
+
+def _write_audio(audio: np.ndarray, sample_rate: int, *, operation: str) -> Path:
+    import soundfile as sf
+
+    out_dir = Path("audio_edits")
+    out_dir.mkdir(parents=True, exist_ok=True)
+    stamp = datetime.now().strftime("%Y%m%d_%H%M%S_%f")
+    out_path = out_dir / f"{operation}_{stamp}.wav"
+    sf.write(str(out_path), audio, sample_rate)
+    return out_path.resolve()
+
+
+def _seconds_to_index(value: float | int | None, sample_rate: int, total_samples: int) -> int:
+    if value is None:
+        return 0
+    try:
+        seconds = float(value)
+    except (TypeError, ValueError):
+        seconds = 0.0
+    idx = int(round(seconds * sample_rate))
+    return max(0, min(total_samples, idx))
+
+
+def _match_channels(audio: np.ndarray, channels: int) -> np.ndarray:
+    if audio.shape[1] == channels:
+        return audio
+    if audio.shape[1] == 1:
+        return np.repeat(audio, channels, axis=1)
+    if channels == 1:
+        return audio.mean(axis=1, keepdims=True)
+    if audio.shape[1] > channels:
+        return audio[:, :channels]
+    pad = np.repeat(audio[:, -1:], channels - audio.shape[1], axis=1)
+    return np.concatenate([audio, pad], axis=1)
+
+
+def _resample_if_needed(audio: np.ndarray, source_sr: int, target_sr: int) -> np.ndarray:
+    if source_sr == target_sr:
+        return audio
+    import torch
+    import torchaudio.functional as F
+
+    tensor = torch.from_numpy(audio.T)
+    resampled = F.resample(tensor, source_sr, target_sr)
+    return resampled.T.numpy().astype("float32", copy=False)
+
+
+def audio_duration_seconds(source_audio: object) -> float:
+    path = _coerce_audio_path(source_audio)
+    audio, sample_rate = _read_audio(path)
+    return audio.shape[0] / float(sample_rate)
+
+
+def resolve_audio_path(source_audio: object) -> str:
+    return str(_coerce_audio_path(source_audio).resolve())
+
+
+def edit_audio_file(
+    source_audio: object,
+    insert_audio: object | None,
+    start_seconds: float | int | None,
+    end_seconds: float | int | None,
+    insert_at_seconds: float | int | None,
+    operation: str,
+) -> tuple[str, str]:
+    source_path = _coerce_audio_path(source_audio)
+    source, sample_rate = _read_audio(source_path)
+    total_samples = source.shape[0]
+    start_idx = _seconds_to_index(start_seconds, sample_rate, total_samples)
+    end_idx = _seconds_to_index(end_seconds, sample_rate, total_samples)
+    if end_idx < start_idx:
+        start_idx, end_idx = end_idx, start_idx
+
+    op = str(operation).strip().lower()
+    if op == "trim":
+        if end_idx <= start_idx:
+            raise ValueError("Trim end seconds must be greater than start seconds.")
+        edited = source[start_idx:end_idx]
+    elif op == "cut":
+        edited = np.concatenate([source[:start_idx], source[end_idx:]], axis=0)
+    elif op == "mute":
+        edited = source.copy()
+        edited[start_idx:end_idx] = 0.0
+    elif op == "insert":
+        insert_path = _coerce_audio_path(insert_audio)
+        insert, insert_sr = _read_audio(insert_path)
+        insert = _resample_if_needed(insert, insert_sr, sample_rate)
+        insert = _match_channels(insert, source.shape[1])
+        insert_idx = _seconds_to_index(insert_at_seconds, sample_rate, total_samples)
+        edited = np.concatenate([source[:insert_idx], insert, source[insert_idx:]], axis=0)
+    else:
+        raise ValueError(f"Unknown audio edit operation: {operation}")
+
+    out_path = _write_audio(edited, sample_rate, operation=op)
+    duration = edited.shape[0] / float(sample_rate)
+    return str(out_path), f"保存先: {out_path}\n長さ: {duration:.3f}秒\nサンプルレート: {sample_rate}"
+
+
+def apply_range_edit(
+    source_audio: object,
+    start_seconds: float | int | None,
+    end_seconds: float | int | None,
+    operation: str,
+    history: list[str] | None,
+) -> tuple[str, str, list[str], list[str]]:
+    source_path = str(_coerce_audio_path(source_audio).resolve())
+    out_path, status = edit_audio_file(
+        source_path,
+        None,
+        start_seconds,
+        end_seconds,
+        None,
+        operation,
+    )
+
+    new_history = list(history or [])
+    if not new_history or str(Path(new_history[-1]).resolve()) != source_path:
+        new_history.append(source_path)
+    new_history.append(out_path)
+    return out_path, status, new_history, []
+
+
+def apply_insert_edit(
+    source_audio: object,
+    insert_audio: object,
+    insert_at_seconds: float | int | None,
+    history: list[str] | None,
+) -> tuple[str, str, list[str], list[str]]:
+    source_path = str(_coerce_audio_path(source_audio).resolve())
+    out_path, status = edit_audio_file(
+        source_path,
+        insert_audio,
+        None,
+        None,
+        insert_at_seconds,
+        "insert",
+    )
+
+    new_history = list(history or [])
+    if not new_history or str(Path(new_history[-1]).resolve()) != source_path:
+        new_history.append(source_path)
+    new_history.append(out_path)
+    return out_path, status, new_history, []
+
+
+def undo_edit(history: list[str] | None, redo_stack: list[str] | None) -> tuple[str, str, list[str], list[str]]:
+    new_history = list(history or [])
+    new_redo = list(redo_stack or [])
+    if len(new_history) <= 1:
+        current = new_history[-1] if new_history else ""
+        return current, "元に戻せる編集がありません", new_history, new_redo
+
+    current = new_history.pop()
+    new_redo.insert(0, current)
+    restored = new_history[-1]
+    return restored, f"元に戻しました: {restored}", new_history, new_redo
+
+
+def redo_edit(history: list[str] | None, redo_stack: list[str] | None) -> tuple[str, str, list[str], list[str]]:
+    new_history = list(history or [])
+    new_redo = list(redo_stack or [])
+    if not new_redo:
+        current = new_history[-1] if new_history else ""
+        return current, "やり直せる編集がありません", new_history, new_redo
+
+    restored = new_redo.pop(0)
+    new_history.append(restored)
+    return restored, f"やり直しました: {restored}", new_history, new_redo
